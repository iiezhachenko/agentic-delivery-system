{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "build-plan",
  "title": "BUILD-PLAN output — component build order with wave grouping and mock map",
  "type": "object",
  "required": ["class", "mode", "build_units", "mock_map", "build_plan_counts"],
  "allOf": [
    {
      "if": { "properties": { "mode": { "const": "skeleton-build" } }, "required": ["mode"] },
      "then": { "required": ["skeleton_id", "walking_skeleton_flow", "build_set", "build_order", "parallel_groups"] }
    },
    {
      "if": { "properties": { "mode": { "const": "slice-build" } }, "required": ["mode"] },
      "then": { "required": ["slice_id", "slice_name", "slice_flow", "build_set", "build_order", "parallel_groups"] }
    }
  ],
  "properties": {
    "skeleton_lock_ref": { "type": "string" },
    "build_dag_ref": { "type": "string" },
    "flows_ref": { "type": "string" },
    "components_ref": { "type": "string" },
    "contracts_ref": { "type": "string" },
    "adr_lock_ref": { "type": "string" },
    "aprd_lock_ref": { "type": "string" },
    "locks_verified": { "type": "boolean" },
    "class": { "type": "string" },
    "mode": { "type": "string" },
    "skeleton_id": { "type": "string" },
    "slice_id": { "type": "string" },
    "slice_name": { "type": "string" },
    "slice_flow": { "type": "string" },
    "walking_skeleton_flow": { "type": "string" },
    "build_set": { "type": "array", "items": { "type": "string" } },
    "prior_built_components": { "type": "array", "items": { "type": "string" } },
    "later_slice_components": { "type": "array", "items": { "type": "string" } },
    "build_order": { "type": "array", "items": { "type": "string" } },
    "parallel_groups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["wave", "components"],
        "properties": {
          "wave": { "type": "integer" },
          "components": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "build_units": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["component", "name", "wave", "traces", "status"],
        "properties": {
          "component": { "type": "string" },
          "name": { "type": "string" },
          "wave": { "type": "integer" },
          "traces": { "type": "array" },
          "provides_contracts": { "type": "array" },
          "consumes_seams": { "type": "array" },
          "mocked_deps": { "type": "array" },
          "status": { "type": "string", "enum": ["planned","green","locked"] }
        }
      }
    },
    "mock_map": { "type": "object" },
    "lock_set": { "type": "array" },
    "coverage": {
      "type": "object",
      "required": ["components_planned"],
      "properties": {
        "path_components": { "type": "array" },
        "components_planned": { "type": "array" },
        "unplanned_path_components": { "type": "array" },
        "slice_flow": { "type": "string" },
        "slice_path_components": { "type": "array" },
        "build_set_components": { "type": "array" },
        "prior_built_on_path": { "type": "array" },
        "unplanned_build_set_components": { "type": "array" },
        "provided_seams": { "type": "array" },
        "consumed_seams_total": { "type": "integer" },
        "consumed_seams_classified": { "type": "integer" },
        "real_seams": { "type": "array" },
        "mocked_seams": { "type": "array" }
      }
    },
    "structural_defects": { "type": "array" },
    "build_plan_counts": {
      "type": "object",
      "required": ["build_units", "real_seams", "mocked_seams", "active_waves"],
      "properties": {
        "build_units": { "type": "integer" },
        "real_seams": { "type": "integer" },
        "mocked_seams": { "type": "integer" },
        "active_waves": { "type": "integer" },
        "locks": { "type": "integer" }
      }
    }
  }
}
