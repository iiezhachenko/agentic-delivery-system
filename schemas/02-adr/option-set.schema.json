{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "option-set",
  "title": "OPTION-GEN output — options per DP* (individual option file, not index)",
  "type": "object",
  "required": ["id", "decision", "category", "forced_by", "grounding", "options", "option_count", "degenerate"],
  "properties": {
    "id": { "type": "string", "pattern": "^DP[0-9]+$" },
    "decision": { "type": "string" },
    "category": { "type": "string" },
    "forced_by": { "type": "array", "items": { "type": "string" } },
    "cut_ref": { "oneOf": [{"type":"string"},{"type":"null"}] },
    "grounding": {
      "type": "object",
      "required": ["existing_system", "canon_status", "source", "note"],
      "properties": {
        "existing_system": { "type": "string" },
        "canon_status": { "type": "string" },
        "source": { "type": "string" },
        "note": { "type": "string" }
      }
    },
    "options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["option", "summary", "source", "reason_to_consider", "tradeoffs", "bears_on"],
        "properties": {
          "option": { "type": "string" },
          "summary": { "type": "string" },
          "source": { "type": "string" },
          "reason_to_consider": { "type": "string" },
          "tradeoffs": {
            "type": "object",
            "required": ["strengths", "costs"],
            "properties": {
              "strengths": { "type": "array", "items": { "type": "string" } },
              "costs": { "type": "array", "items": { "type": "string" } }
            }
          },
          "bears_on": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "option_count": { "type": "integer", "minimum": 1 },
    "degenerate": { "type": "boolean" },
    "degenerate_reason": { "oneOf": [{"type":"string"},{"type":"null"}] },
    "no_pick_note": { "type": "string" }
  }
}
