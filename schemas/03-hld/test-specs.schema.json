{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "test-specs",
  "title": "DERIVE-TESTS output — design-layer test spec (contract tests + flow tests + build-dag)",
  "type": "object",
  "required": ["class", "mode"],
  "allOf": [
    {
      "if": { "properties": { "mode": { "const": "skeleton" } }, "required": ["mode"] },
      "then": { "required": ["contract_tests", "flow_tests", "coverage", "test_counts"] }
    },
    {
      "if": { "properties": { "mode": { "const": "increment" } }, "required": ["mode"] },
      "then": { "required": ["flow_tests", "inherited_contract_tests", "new_contract_tests", "coverage", "test_counts"] }
    }
  ],
  "properties": {
    "contracts_ref": { "type": "string" },
    "flows_ref": { "type": "string" },
    "components_ref": { "type": "string" },
    "aprd_ref": { "type": "string" },
    "foundation_cut_ref": { "type": "string" },
    "adr_lock_ref": { "type": "string" },
    "lock_verified": { "type": "boolean" },
    "class": { "type": "string" },
    "mode": { "type": "string" },
    "skeleton_id": { "type": "string" },
    "skeleton_lock_ref": { "type": "string" },
    "base_test_specs_ref": { "type": "string" },
    "base_contracts_ref": { "type": "string" },
    "slice_flows_ref": { "type": "string" },
    "slice_contracts_ref": { "type": "string" },
    "skeleton_frozen_verified": { "type": "boolean" },
    "slice_id": { "type": "string" },
    "slice_name": { "type": "string" },
    "layer": { "type": "string" },
    "inherited_contract_tests": { "type": "array" },
    "new_contract_tests": { "type": "array" },
    "skeleton_fidelity": { "type": "object" },
    "increment_counts": { "type": "object" },
    "contract_tests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "target", "between", "contract_kind"],
        "properties": {
          "id": { "type": "string" },
          "target": { "type": "string" },
          "between": { "type": "array" },
          "contract_kind": { "type": "string" },
          "file": { "type": "string" },
          "mocked_deps": { "type": "array" },
          "shape_test": { "type": "string" },
          "failure_tests": { "type": "array", "items": { "type": "string" } },
          "failure_modes": { "type": "array", "items": { "type": "string" } },
          "traces": { "type": "array" }
        }
      }
    },
    "flow_tests": { "type": "array" },
    "acceptance_tests": { "type": "array" },
    "coverage": { "type": "object" },
    "aprd_defects": { "type": "array" },
    "frame_conflicts": { "type": "array" },
    "structural_defects": { "type": "array" },
    "test_counts": { "type": "object" }
  }
}
