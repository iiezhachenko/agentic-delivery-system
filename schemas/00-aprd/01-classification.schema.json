{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "01-classification",
  "title": "CLASSIFIER output — subrequests + class + confidence + confirmation questions",
  "type": "object",
  "required": ["request_ref", "is_compound", "overall_confidence", "needs_confirmation", "subrequests", "confirmation_questions"],
  "properties": {
    "request_ref": { "type": "string", "description": "path to raw request file" },
    "is_compound": { "type": "boolean", "description": "true when request spans >1 class or >1 distinct work-order" },
    "overall_confidence": { "type": "number", "minimum": 0, "maximum": 1, "description": "min over subrequest confidences (weakest link)" },
    "needs_confirmation": { "type": "boolean", "description": "true iff confidence < threshold OR compound OR any subrequest unplaybooked" },
    "subrequests": {
      "type": "array",
      "description": "atomic subrequests; each SR* stable, never renumbered",
      "items": {
        "type": "object",
        "required": ["id", "text", "class", "confidence", "reason"],
        "properties": {
          "id": { "type": "string", "pattern": "^SR[0-9]+$" },
          "text": { "type": "string" },
          "class": { "type": "string", "enum": ["greenfield","feature-add","bugfix","refactor","migration","perf","integration","investigation"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "reason": { "type": "string", "description": "words in request that drove this class" }
        }
      }
    },
    "confirmation_questions": {
      "type": "array",
      "description": "[] when needs_confirmation is false",
      "items": {
        "type": "object",
        "required": ["id", "question", "options", "default", "targets"],
        "properties": {
          "id": { "type": "string", "pattern": "^Q[0-9]+$" },
          "question": { "type": "string" },
          "options": { "type": "array", "items": { "type": "string" } },
          "default": { "type": "string" },
          "targets": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "escape": {
      "description": "null when every subrequest has an authored playbook",
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["unplaybooked_subrequests", "note"],
          "properties": {
            "unplaybooked_subrequests": { "type": "array", "items": { "type": "string" } },
            "note": { "type": "string" }
          }
        }
      ]
    }
  }
}
